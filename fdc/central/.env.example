# ============================================================
#  คอนฟิกศูนย์บัญชาการ — คัดลอกเป็น .env แล้วแก้ค่า (อย่า commit .env)
# ============================================================

# ---- ฐานข้อมูล ----
DB_USER=fdc
DB_PASSWORD=change-me-strong-password
DB_NAME=fdc
DB_PORT=5432

# ---- พอร์ตภายนอก ----
MQTT_PORT=8883
API_PORT=8000

# ---- คีย์เซ็นคำสั่งยิง downlink (HMAC-SHA256, hex) ----
# คีย์เดียวกับที่ตั้งใน ศอย. (env FDC_CMD_HMAC_KEY ฝั่ง main.py/uplink.py)
# หลายหน่วย: ใช้ JSON map (คีย์ต่อหน่วย) — แนะนำสำหรับระดับประเทศ
# FDC_CMD_HMAC_KEYS={"BN1-A":"<hex64>","BN1-B":"<hex64>"}
# หน่วยเดียว/ทดสอบ: ใช้คีย์เดี่ยว
FDC_CMD_HMAC_KEY=

# ---- Auth / RBAC (STEP D3) ----
AUTH_ENABLED=true
# กุญแจเซ็น JWT — สุ่มยาว (เช่น: openssl rand -hex 32) อย่าใช้ค่าตัวอย่าง
JWT_SECRET=
JWT_TTL_MIN=720
# ผู้ดูแลตั้งต้น — สร้างให้อัตโนมัติตอนสตาร์ทถ้ายังไม่มีผู้ใช้เลย
ADMIN_USER=admin
ADMIN_PASSWORD=
